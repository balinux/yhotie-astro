---
type BreadcrumbItem = {
  label: string;
  href: string | null;
};

const SECTION_LABELS: Record<string, string> = {
  posts: "Posts",
  tags: "Tags",
  galleries: "Galerías",
  archives: "Archivos",
  search: "Buscar",
  about: "About",
};

const normalizedPath =
  Astro.url.pathname.endsWith("/") && Astro.url.pathname !== "/"
    ? Astro.url.pathname.slice(0, -1)
    : Astro.url.pathname;

const pathSegments = normalizedPath.split("/").filter(Boolean);

const isNumericSegment = (value?: string) =>
  typeof value === "string" && /^\d+$/.test(value);

const decodeSegment = (value: string) => {
  try {
    return decodeURIComponent(value);
  } catch {
    return value;
  }
};

const formatSegmentLabel = (segment: string) => {
  const sectionLabel = SECTION_LABELS[segment];
  if (sectionLabel) return sectionLabel;

  const readable = decodeSegment(segment)
    .replace(/[-_]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();

  if (!readable) return segment;

  return readable.charAt(0).toUpperCase() + readable.slice(1);
};

const buildDefaultBreadcrumbs = (segments: string[]): BreadcrumbItem[] =>
  segments.map((segment, index) => ({
    label: formatSegmentLabel(segment),
    href:
      index === segments.length - 1
        ? null
        : `/${segments.slice(0, index + 1).join("/")}/`,
  }));

const buildBreadcrumbs = (segments: string[]): BreadcrumbItem[] => {
  if (segments.length === 0) return [];

  // /posts/2 -> Home > Posts (página 2)
  if (segments[0] === "posts" && segments.length === 2 && isNumericSegment(segments[1])) {
    const page = Number(segments[1]);
    return [{ label: page > 1 ? `Posts (página ${page})` : "Posts", href: null }];
  }

  // /tags/react/2 -> Home > Tags > React (página 2)
  if (segments[0] === "tags" && segments[1] && segments.length === 3 && isNumericSegment(segments[2])) {
    const page = Number(segments[2]);
    const tagLabel = formatSegmentLabel(segments[1]);

    return [
      { label: "Tags", href: "/tags/" },
      {
        label: page > 1 ? `${tagLabel} (página ${page})` : tagLabel,
        href: null,
      },
    ];
  }

  return buildDefaultBreadcrumbs(segments);
};

const breadcrumbs = buildBreadcrumbs(pathSegments);
---

<nav class="app-layout mt-6 mb-2" aria-label="breadcrumb">
  <ol class="breadcrumb-bar font-cartograph text-sm">
    <li class="breadcrumb-item">
      <a
        href="/"
        class="breadcrumb-home"
        aria-label="Inicio"
        title="Inicio"
      >
        ~
      </a>
    </li>
    {
      breadcrumbs.map(item => (
        <li class="breadcrumb-item">
          {item.href ? (
            <a href={item.href} class="breadcrumb-link">
              {item.label}
            </a>
          ) : (
            <span class="breadcrumb-current" aria-current="page">
              {item.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .breadcrumb-bar {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    max-width: 100%;
    overflow-x: auto;
    padding: 0.4rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--border) 30%, transparent);
    border-radius: 999px;
    background:
      linear-gradient(
        130deg,
        color-mix(in srgb, var(--accent) 10%, transparent) 0%,
        transparent 44%
      ),
      color-mix(in srgb, var(--foreground) 3%, var(--background));
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 20%, transparent),
      0 10px 28px -20px color-mix(in srgb, var(--accent) 45%, transparent);
    -webkit-backdrop-filter: blur(10px) saturate(125%);
    backdrop-filter: blur(10px) saturate(125%);
    scrollbar-width: none;
    animation: breadcrumb-in 0.35s ease-out both;
  }

  .breadcrumb-bar::-webkit-scrollbar {
    display: none;
  }

  .breadcrumb-item {
    flex-shrink: 0;
    min-width: 0;
    display: inline-flex;
    align-items: center;
  }

  .breadcrumb-item + .breadcrumb-item::before {
    content: "/";
    margin-inline: 0.3rem;
    opacity: 0.6;
    color: color-mix(in srgb, var(--accent) 65%, var(--foreground));
  }

  .breadcrumb-home,
  .breadcrumb-link,
  .breadcrumb-current {
    display: inline-flex;
    align-items: center;
    border-radius: 0.45rem;
    line-height: 1;
    text-decoration: none;
  }

  .breadcrumb-home {
    justify-content: center;
    width: 1.65rem;
    height: 1.65rem;
    color: color-mix(in srgb, var(--foreground) 65%, transparent);
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      transform 0.2s ease;
  }

  .breadcrumb-home:hover,
  .breadcrumb-home:focus-visible {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 9%, transparent);
    transform: translateY(-1px);
  }

  .breadcrumb-link,
  .breadcrumb-current {
    padding: 0.35rem 0.55rem;
    white-space: nowrap;
  }

  .breadcrumb-link {
    color: color-mix(in srgb, var(--foreground) 72%, transparent);
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .breadcrumb-link:hover,
  .breadcrumb-link:focus-visible {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .breadcrumb-current {
    max-width: min(34ch, 56vw);
    overflow: hidden;
    text-overflow: ellipsis;
    color: color-mix(in srgb, var(--accent) 92%, var(--foreground));
    background: color-mix(in srgb, var(--accent) 11%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 24%, transparent);
  }

  @media (max-width: 640px) {
    .breadcrumb-current {
      max-width: min(24ch, 58vw);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .breadcrumb-bar,
    .breadcrumb-home,
    .breadcrumb-link {
      animation: none;
      transition: none;
    }
  }

  @keyframes breadcrumb-in {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
